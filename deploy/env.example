COMFYUI_BASE_URL=http://comfyui:8188
COMFYUI_API_KEY=
COMFYUI_OUTPUT_ROOT=/data/comfy-output
COMFYUI_ROOT=/opt/ComfyUI

PLATFORM_API_TOKEN=change-me
PLATFORM_SESSION_SECRET=change-me-session-secret
PLATFORM_SESSION_TTL_SECONDS=86400
PLATFORM_CORS_ORIGINS=https://studio.example.com

PLATFORM_REPOSITORY_DRIVER=postgres
PLATFORM_DATABASE_URL=postgresql://video_gen:video_gen@postgres:5432/video_gen
PLATFORM_DATABASE_TABLE=video_gen_records

PLATFORM_TASK_QUEUE_DRIVER=arq
PLATFORM_REDIS_URL=redis://redis:6379/0
PLATFORM_TASK_QUEUE_NAME=video_gen

PLATFORM_STORAGE_DRIVER=s3
PLATFORM_STORAGE_ROOT=/data/storage
PLATFORM_S3_ENDPOINT_URL=https://oss.example.com
PLATFORM_S3_BUCKET=video-gen
PLATFORM_S3_ACCESS_KEY=change-me
PLATFORM_S3_SECRET_KEY=change-me
PLATFORM_S3_REGION=us-east-1
PLATFORM_S3_PREFIX=prod
PLATFORM_S3_PUBLIC_BASE_URL=https://cdn.example.com/prod
PLATFORM_S3_VENDOR=custom
PLATFORM_S3_FORCE_PATH_STYLE=true
PLATFORM_S3_UPLOAD_TIMEOUT_SECONDS=30
PLATFORM_S3_ALLOW_INSECURE_ENDPOINT=false

PLATFORM_ALERT_WEBHOOK_URL=
PLATFORM_ALERT_WEBHOOK_SECRET=
PLATFORM_ALERT_CHANNEL=generic
PLATFORM_ALERT_TIMEOUT_SECONDS=10
PLATFORM_ALERT_COOLDOWN_SECONDS=1800
PLATFORM_ALERT_STATE_PATH=/data/storage/alert-state.json

PLATFORM_PAYMENT_WEBHOOK_SECRET=change-me-payment-webhook-secret
PLATFORM_PAYMENT_CHECKOUT_URL_TEMPLATE=https://pay.example.com/checkout/{order_id}?amount={amount_cents}&currency={currency}
PLATFORM_PAYMENT_STRIPE_CHECKOUT_URL_TEMPLATE=https://checkout.stripe.example.com/session/{order_id}?amount={amount_cents}&currency={currency}

PLATFORM_PAYOUT_WEBHOOK_URL=
PLATFORM_PAYOUT_WEBHOOK_SECRET=
PLATFORM_PAYOUT_PROVIDER=manual
PLATFORM_PAYOUT_TIMEOUT_SECONDS=10
